{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.jsdelivr.net/gh/forge-arcana/kod-data@main/schema/observations.schema.json",
  "title": "Keppet Observation",
  "description": "One tidy long-form row of the archive — the NDJSON substrate every domain reduces to.",
  "type": "object",
  "required": ["date", "domain", "instrument", "field", "value", "unit", "source"],
  "additionalProperties": false,
  "properties": {
    "date": {
      "description": "Effective date of the observation (UTC).",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "domain": {
      "type": "string",
      "enum": ["fx", "metals", "crypto", "rates", "yields"]
    },
    "instrument": {
      "description": "What was measured, e.g. EUR, XAU, BTC, SOFR, US.",
      "type": "string"
    },
    "field": {
      "description": "Which quantity of the instrument, e.g. rate, price, percent, 10Y.",
      "type": "string"
    },
    "value": { "type": "number" },
    "unit": { "type": "string" },
    "source": { "type": "string" }
  }
}
