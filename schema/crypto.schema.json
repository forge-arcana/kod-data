{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.jsdelivr.net/gh/forge-arcana/kod-data@main/schema/crypto.schema.json",
  "title": "Keppet Crypto",
  "description": "USD spot prices for the top digital assets by market capitalisation.",
  "type": "object",
  "required": ["dataset", "base", "unit", "date", "updated", "sources", "sourcesMeta", "count", "prices", "assets"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "dataset": { "const": "crypto" },
    "base": { "const": "USD" },
    "unit": { "const": "usd" },
    "date": {
      "description": "UTC date the spot snapshot was stamped (feed is real-time).",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "sourcesMeta": {
      "description": "Per-source effective date — drives status.json per-feed freshness.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["date"],
        "additionalProperties": false,
        "properties": { "date": { "type": "string", "pattern": "^(\\d{4}-\\d{2}-\\d{2})?$" } }
      }
    },
    "count": { "type": "integer", "minimum": 0 },
    "prices": {
      "description": "Symbol -> USD price. Dominant coin wins on symbol collision.",
      "type": "object",
      "propertyNames": { "pattern": "^[A-Z0-9]{2,15}$" },
      "patternProperties": {
        "^[A-Z0-9]{2,15}$": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rank", "symbol", "name", "id", "price", "market_cap", "volume_24h", "change_24h"],
        "additionalProperties": false,
        "properties": {
          "rank": { "type": ["integer", "null"], "minimum": 1 },
          "symbol": { "type": "string", "pattern": "^[A-Z0-9]{2,15}$" },
          "name": { "type": "string" },
          "id": { "type": "string" },
          "price": { "type": "number", "exclusiveMinimum": 0 },
          "market_cap": { "type": ["integer", "null"], "minimum": 0 },
          "volume_24h": { "type": ["integer", "null"], "minimum": 0 },
          "change_24h": { "type": ["number", "null"] }
        }
      }
    }
  }
}
