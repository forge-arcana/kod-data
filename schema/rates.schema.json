{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.jsdelivr.net/gh/forge-arcana/kod-data@main/schema/rates.schema.json",
  "title": "Keppet Rates",
  "description": "Benchmark reference rates and central-bank policy rates, percent per annum.",
  "type": "object",
  "required": ["dataset", "date", "updated", "sources", "sourcesMeta", "reference", "policy"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "dataset": { "const": "rates" },
    "base": { "const": "USD" },
    "date": {
      "description": "Freshest effective date across all sources (UTC), not build time. Each rate also carries its own effective date.",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "sourcesMeta": {
      "description": "Per-source effective date — drives status.json per-feed freshness.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["date"],
        "additionalProperties": false,
        "properties": { "date": { "type": "string", "pattern": "^(\\d{4}-\\d{2}-\\d{2})?$" } }
      }
    },
    "reference": {
      "description": "Overnight risk-free benchmark id (SOFR, ESTR, ...) -> rate.",
      "type": "object",
      "propertyNames": { "pattern": "^[A-Z0-9]+$" },
      "additionalProperties": {
        "type": "object",
        "required": ["percent", "date", "source"],
        "additionalProperties": false,
        "properties": {
          "percent": { "type": "number" },
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
          "source": { "type": "string" }
        }
      }
    },
    "policy": {
      "description": "Reporting-authority REF_AREA -> headline policy rate.",
      "type": "object",
      "propertyNames": { "pattern": "^[A-Z0-9_]+$" },
      "additionalProperties": {
        "type": "object",
        "required": ["percent", "date"],
        "additionalProperties": false,
        "properties": {
          "percent": { "type": "number" },
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    }
  }
}
