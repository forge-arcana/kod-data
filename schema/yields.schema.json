{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.jsdelivr.net/gh/forge-arcana/kod-data@main/schema/yields.schema.json",
  "title": "Keppet Yields",
  "description": "Sovereign benchmark yield curves, percent per annum by tenor.",
  "type": "object",
  "required": ["dataset", "date", "updated", "sources", "sourcesMeta", "curves"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "dataset": { "const": "yields" },
    "base": { "const": "USD" },
    "date": {
      "description": "Latest session date of the freshest curve (UTC).",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "sourcesMeta": {
      "description": "Per-source effective date — drives status.json per-feed freshness.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["date"],
        "additionalProperties": false,
        "properties": { "date": { "type": "string", "pattern": "^(\\d{4}-\\d{2}-\\d{2})?$" } }
      }
    },
    "curves": {
      "description": "Sovereign area (ISO, e.g. US, DE) -> its tenor curve.",
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "pattern": "^[A-Z]{2,3}$" },
      "additionalProperties": {
        "type": "object",
        "required": ["unit", "tenors"],
        "additionalProperties": false,
        "properties": {
          "unit": { "const": "percent" },
          "tenors": {
            "description": "Canonical tenor (ON, TN, SN, 1M, 6M, 2Y, 10Y, ...) -> yield in percent.",
            "type": "object",
            "minProperties": 1,
            "propertyNames": { "pattern": "^([0-9.]+[A-Z]|ON|TN|SN)$" },
            "additionalProperties": { "type": "number" }
          }
        }
      }
    }
  }
}
