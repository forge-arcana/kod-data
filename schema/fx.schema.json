{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cdn.jsdelivr.net/gh/forge-arcana/kod-data@main/schema/fx.schema.json",
  "title": "Keppet FX",
  "description": "USD-anchored foreign-exchange rates. Each value is units of the currency per 1 USD.",
  "type": "object",
  "required": ["dataset", "base", "unit", "date", "updated", "sources", "sourcesMeta", "rates"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "format": "uri" },
    "dataset": { "const": "fx" },
    "base": { "const": "USD" },
    "unit": { "const": "per_usd" },
    "date": {
      "description": "Effective date of the freshest daily source (UTC), not build time.",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": { "type": "string", "format": "date-time" },
    "sources": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "sourcesMeta": {
      "description": "Per-source effective date — drives status.json per-feed freshness.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["date"],
        "additionalProperties": false,
        "properties": { "date": { "type": "string", "pattern": "^(\\d{4}-\\d{2}-\\d{2})?$" } }
      }
    },
    "rates": {
      "description": "ISO-4217 code (plus metals XAU/XAG/XPT/XPD) -> units per 1 USD.",
      "type": "object",
      "required": ["USD"],
      "propertyNames": { "pattern": "^[A-Z]{3}$" },
      "patternProperties": {
        "^[A-Z]{3}$": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
